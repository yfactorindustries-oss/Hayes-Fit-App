                { "id": "d5_glute_bridge", "label": "Glute Bridge Hold", "sets": 3, "durationSeconds": 30, "notes": "Hip rehab maintenance. 30 sec hold. Rest 0:30", "restSeconds": 30 }
              ]
            },
            {
              "title": "Mobility During Rest",
              "exercises": [
                { "id": "d5_mob", "label": "Dead Hang", "details": "Between pulling sets" }
