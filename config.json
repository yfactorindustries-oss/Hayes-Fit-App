{
  "programName": "Hayes Fit – Phase 2: Hypertrophy + Durability",
  "configVersion": 2,
  "notes": "Phase 2 (8 weeks). 5-day push/pull/legs rotation. Sequential: Day1 -> Day2 -> Day3 -> Day4 -> Day5, resume where you left off.",

  "blocks": [
    {
      "id": "phase2",
      "name": "Phase 2 – Hypertrophy + Durability",
      "startDate": "2026-03-20",
      "endDate": "2026-05-14",
      "weekRange": "Weeks 1-8",
      "rotationType": "sequential",
      "rotationOrder": ["phase2_push_heavy", "phase2_pull_heavy", "phase2_legs_core", "phase2_push_hyper", "phase2_pull_hyper"],
      "notes": "5 training days, sequential rotation. Upper body hypertrophy priority, leg maintenance, neutral grip on all pressing/pulling.",

      "dailyRehab": [
        {
          "id": "daily_dead_hang",
          "label": "Dead Hang",
          "details": "2 × 30-45 sec – full relaxation, grip work",
          "sets": 2,
          "reps": "30-45 sec"
        },
        {
          "id": "daily_hip_cars",
          "label": "Hip CARs",
          "details": "Slow and controlled, full ROM",
          "sets": 1,
          "reps": "2/side"
        },
        {
          "id": "daily_tspine_openbooks",
          "label": "T-Spine Open Books",
          "details": "Slow, exhale into rotation",
          "sets": 1,
          "reps": "5/side"
        }
      ],

      "workouts": [
        {
          "id": "phase2_push_heavy",
          "name": "Day 1: Push (Heavy)",
          "order": 0,
          "notes": "Shoulder + chest strength focus. RPE 7-8. ~40 min.",
