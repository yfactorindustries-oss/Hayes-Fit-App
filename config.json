                { "id": "d5_cable_row", "label": "Cable Row (close neutral grip)", "sets": 3, "reps": "12-15", "notes": "Squeeze at contraction. Rest 1:00", "restSeconds": 60, "equipmentChoice": true },
                { "id": "d5_sa_pulldown", "label": "Straight-Arm Pulldown", "sets": 3, "reps": "12-15", "notes": "Lats, stretch at top. Rest 1:00", "restSeconds": 60, "equipmentChoice": true },
