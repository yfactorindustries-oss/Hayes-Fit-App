            {
              "title": "Warm-Up (3 min)",
              "exercises": [
                { "id": "warmup_d1_circles", "label": "Arm Circles", "details": "10 each direction" },
                { "id": "warmup_d1_pullaparts", "label": "Band Pull-Aparts", "reps": "15", "details": "15 reps" },
                { "id": "warmup_d1_tspine", "label": "T-Spine Rotation", "reps": "5/side", "details": "5/side (also do during rest periods)" }
              ]
            },
            {
              "title": "Strength",
              "exercises": [
                { "id": "d1_ohp", "label": "Seated DB Overhead Press (neutral grip)", "sets": 4, "reps": "6-8", "notes": "Main lift, RPE 7-8. Rest 2:00", "restSeconds": 120, "equipmentChoice": true },
                { "id": "d1_flat_press", "label": "Flat DB Press (neutral grip)", "sets": 3, "reps": "8-10", "notes": "Control eccentric. Rest 1:30", "restSeconds": 90, "equipmentChoice": true },
                { "id": "d1_lat_raise", "label": "Lateral Raise", "sets": 3, "reps": "12-15", "notes": "Slow, no momentum. Rest 1:00", "restSeconds": 60, "equipmentChoice": true },
