              ]
            },
            {
              "title": "Mobility During Rest",
              "exercises": [
                { "id": "d1_mob", "label": "T-Spine Open Books", "details": "3-5/side between pressing sets" }
              ]
            }
          ]
        },
        {
          "id": "phase2_pull_heavy",
